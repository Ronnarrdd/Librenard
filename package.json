{
  "name": "librenard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node scripts/build-site.mjs",
    "check:links": "node scripts/check-links.mjs",
    "check:links:external": "node scripts/check-links.mjs --external",
    "postinstall": "node scripts/lib/vendor-assets.mjs",
    "test": "node --test scripts/**/*.test.mjs",
    "verify": "npm run test && npm run build && npm run check:links"
  },
  "devDependencies": {
    "@fontsource/comic-neue": "^5.2.7",
    "@fontsource/fredoka": "^5.2.10",
    "@fontsource/nunito": "^5.2.7",
    "highlight.js": "^11.11.1",
    "js-beautify": "^2.0.3",
    "open-dyslexic": "^1.0.3",
    "pagefind": "^1.5.2",
    "sharp": "^0.35.3"
  }
}
